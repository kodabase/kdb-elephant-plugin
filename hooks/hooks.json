{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/ensure-running.sh",
            "timeout": 15,
            "statusMessage": "Starting Elephant worker..."
          },
          {
            "type": "http",
            "url": "http://127.0.0.1:37888/api/hooks/session-start",
            "timeout": 15,
            "statusMessage": "Loading standards context..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:37888/api/hooks/pre-tool-use",
            "timeout": 5,
            "statusMessage": "Checking standards compliance..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:37888/api/hooks/post-tool-use",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:37888/api/hooks/stop",
            "timeout": 10,
            "statusMessage": "Saving session data..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:37888/api/hooks/session-end",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
